{
    "DefaultDb": "Postgres",
    "ConnectionStrings": {
        "SQlite": "Data Source=game.db",
        "MSSQL": "Server=(localdb)\\MSSQLLocalDB;Database=game;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;",
        "MySQL": "Server=localhost;Database=game;User=;Password=;",
        "Postgres": "Host=localhost;Port=5432;Database=game;Username=;Password=;Ssl Mode=Disable",
        "ApplicationContext": "Data Source=ApplicationContext.db"
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/log-.txt",
                    "rollingInterval": "Day",
                    "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId"
        ]
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
