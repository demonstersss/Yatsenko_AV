@page
@model Yatsenko_AV.Pages.Genres.IndexModel
@{
    ViewData["Title"] = "Жанры";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📂 Список жанров</h2>
        <a href="/Genres/Create" class="btn btn-success shadow-sm">+ Добавить жанр</a>
    </div>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Название жанра</th>
                <th class="text-center">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var genre in Model.Genres)
            {
                <tr>
                    <td>@genre.Id</td>
                    <td><strong>@genre.Name</strong></td>
                    <td class="text-center">
                        <a asp-page="Edit" asp-route-id="@genre.Id" class="btn btn-sm btn-primary me-1">Изменить</a>
                        <a asp-page="Delete" asp-route-id="@genre.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>