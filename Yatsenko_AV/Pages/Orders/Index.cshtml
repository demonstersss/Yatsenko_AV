@page
@model Yatsenko_AV.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Предзаказы";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Список предзаказов</h2>
        <a href="/Orders/Create" class="btn btn-success shadow-sm">+ Добавить предзаказ</a>
    </div>

    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Игра</th>
                <th>Логин покупателя</th>
                <th>Дата оформления</th>
                <th>Количество</th>
                <th class="text-center">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td><strong>@order.Game?.Name</strong></td>
                    <td>@order.CustomerName</td>
                    <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                    <td>@order.Quantity</td>
                    <td class="text-center">
                        <a asp-page="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-primary me-1">Изменить</a>
                        <a asp-page="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a asp-page="/Games/Index" class="btn btn-secondary">← Вернуться к списку игр</a>
    </div>
</div>