@page
@model Yatsenko_AV.Pages.Orders.CreateModel
@{
    ViewData["Title"] = "Добавить предзаказ";
}

<div class="container mt-4">
    <h2>📦 Добавить предзаказ</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Order.GameId" class="form-label">Игра</label>
                    <select asp-for="Order.GameId" class="form-control" asp-items="Model.GamesList"></select>
                    <span asp-validation-for="Order.GameId" class="text-danger"></span>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="mb-3">
                        <label asp-for="Order.CustomerName" class="form-label">Логин покупателя</label>
                        <input asp-for="Order.CustomerName" class="form-control" />
                        <span asp-validation-for="Order.CustomerName" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="Order.CustomerName" />
                }

                <div class="mb-3">
                    <label asp-for="Order.Quantity" class="form-label">Количество</label>
                    <input asp-for="Order.Quantity" class="form-control" type="number" min="1" value="1" />
                    <span asp-validation-for="Order.Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-success shadow-sm">Сохранить</button>
                    <a asp-page="/Games/Index" class="btn btn-secondary">Назад к списку</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}