@page
@model Yatsenko_AV.Pages.Developers.IndexModel
@{
    ViewData["Title"] = "Разработчики";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🏢 Список разработчиков</h2>
        <a href="/Developers/Create" class="btn btn-success shadow-sm">+ Добавить разработчика</a>
    </div>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Название разработчика</th>
                <th class="text-center">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dev in Model.Developers)
            {
                <tr>
                    <td>@dev.Id</td>
                    <td><strong>@dev.Name</strong></td>
                    <td class="text-center">
                        <a asp-page="Edit" asp-route-id="@dev.Id" class="btn btn-sm btn-primary me-1">Изменить</a>
                        <a asp-page="Delete" asp-route-id="@dev.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>