@page
@model Yatsenko_AV.Pages.IndexModel
@{
    ViewData["Title"] = "Главная";
}

<div class="container mt-5">
    <greeting></greeting>
    <div class="text-center mb-5">
        <h1 class="display-4">🎮 Razor_PG</h1>
        <p class="lead">Каталог видеоигр — управление данными</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="list-group shadow-sm">
                <a href="/Games" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center fs-5 py-3">
                    <span>🎲 Игры</span>
                    <span class="badge bg-primary rounded-pill">@Model.GameCount</span>
                </a>
                <a href="/Genres" class="list-group-item list-group-item-action fs-5 py-3">
                    📂 Жанры
                </a>
                <a href="/Developers" class="list-group-item list-group-item-action fs-5 py-3">
                    🏢 Разработчики
                </a>
            </div>
        </div>
    </div>
</div>